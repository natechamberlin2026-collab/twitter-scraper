// .env.example
# Twitter Scraper Configuration
# Note: Twitter/X requires login for most scraping. Use authenticated session cookies.

# For authenticated scraping (export cookies from browser)
TWITTER_AUTH_TOKEN=your_auth_token_here
TWITTER_CT0=your_csrf_token_here

# Scraping settings
HEADLESS=true
SCROLL_DELAY_MS=2000
MAX_TWEETS=100
OUTPUT_DIR=./output
OUTPUT_FORMAT=json  # json or csv